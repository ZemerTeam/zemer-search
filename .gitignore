node_modules/

# local machine config and env (real paths, never commit)
*.local.md
.env

# built corpus — large binary, rebuilt from cache
data/corpus.db
data/corpus.db-shm
data/corpus.db-wal

# harvested HTTP cache — 13k+ gzipped YouTube API responses
data/.httpcache/

# derived from Firestore (fetched with a private API key)
data/whitelist.json
data/blocked-ids.json

# derived on-device search subset — rebuilt via `node index/build-subset.mjs`
data/subset.json.gz

# data-driven auto playlists (Top 50 / Trending / Favorites) — regenerated on the VPS by
# harvester/auto-playlists.mjs from usage telemetry; the hand-curated zemer-playlists.json stays committed
data/zemer-playlists-auto.json

# auto-discovered clearly-labeled acapella releases (folded into the acapella playlist) — VPS-local,
# maintained by harvester/auto-playlists.mjs; the committed acapella curation stays pristine
data/acapella-auto.json

# rank-history sidecar (each run's list orderings + 7d play reach; feeds future velocity/chart-movement)
data/auto-playlists-history.json

# transient maintenance progress status (runtime only — written by the harvest/refresh steps)
data/.maintain-status.json*
data/.releases-status.json*

# local DB/whitelist backups (timestamped snapshots; never published)
backups/

# logs
data/.harvest-full.log
data/.harvest-sqlite.log
data/.api.log
data/.playlists-*.log
data/.meta-validate.log
data/.releases.log
data/.wrapup.log

# generated review report — non-whitelisted artists seen in community playlists (regenerated each run)
data/rejected-artists.json
data/rejected-artists.txt

# secrets (not in this dir by default, but guard against accidents)
innertube_cookie.txt
google-services.json
